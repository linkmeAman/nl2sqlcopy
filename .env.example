# PostgreSQL with pgvector — accessible via Tailscale from App Server
DATABASE_URL=postgresql://user:pass@<tailscale-ip>:5432/ragdb

# Embedding provider. "custom" preserves the existing bge/TEI-style HTTP server.
# Supported: custom, openai, gemini, ollama, voyageai
EMBEDDING_PROVIDER=custom
EMBEDDING_API_URL=http://<tailscale-ip>:8000/embed
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Model name stored with every embedded chunk for traceability
EMBEDDING_MODEL=bge-large-en-v1.5

# Number of texts sent per HTTP call to the embedding server
BATCH_SIZE=32

# Must match the model's actual output dimension (bge-large-en-v1.5 = 1024)
EMBEDDING_DIMENSION=1024

# HTTP timeout in seconds for each embedding API call
EMBED_TIMEOUT=30.0

# Max retry attempts on transient embedding server failures (5xx / timeout)
EMBED_MAX_RETRIES=3

# Base delay (seconds) for exponential backoff between retries
EMBED_RETRY_BASE_DELAY=1.0

# LLM provider. Supported: ollama, openai, anthropic, gemini, groq,
# openrouter, togetherai. Cloud providers require the matching *_API_KEY.
# Secrets may also be loaded as file:/run/secrets/name or env:ENV_VAR_NAME.
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=deepseek-coder:6.7b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY=0.5
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=

# Optional per-workload model routing. Unset values inherit LLM_*.
SQL_MODEL_PROVIDER=
SQL_MODEL=
SQL_MODEL_API_KEY=
SQL_MODEL_BASE_URL=
SQL_FALLBACK_PROVIDER=
SQL_FALLBACK_MODEL=

REASONING_MODEL_PROVIDER=
REASONING_MODEL_API_KEY=
REASONING_MODEL_BASE_URL=
REASONING_FALLBACK_PROVIDER=
REASONING_FALLBACK_MODEL=
REASONING_FALLBACK_API_KEY=
REASONING_FALLBACK_BASE_URL=

# Reasoning model for ReAct Thought/Action steps
# Separate from LLM_MODEL (deepseek-coder for generation)
# qwen3:4b uses hybrid thinking mode — produces
# <think> block before answering. Enabled via
# "thinking": true in Ollama options.
# Temperature 0.6 is recommended for reasoning quality.
# Do not use temperature 0.0 for reasoning model —
# it degrades thinking quality.
# deepseek-coder still uses temperature 0.0 for SQL.
REASONING_MODEL=qwen3:4b
REASONING_TEMPERATURE=0.6
REASONING_TIMEOUT=45
REACT_MAX_ITERATIONS=4
ANSWER_MODEL_PROVIDER=
ANSWER_MODEL=
ANSWER_MODEL_API_KEY=
ANSWER_MODEL_BASE_URL=
ANSWER_FALLBACK_PROVIDER=
ANSWER_FALLBACK_MODEL=
ANSWER_FALLBACK_API_KEY=
ANSWER_FALLBACK_BASE_URL=
ANSWER_TIMEOUT=60
SQL_GENERATION_TIMEOUT=180
ASK_TIMEOUT=260


# Output SQL syntax only — unrelated to pgvector store engine
# mysql = MySQL-compatible SELECT syntax in generated SQL
SQL_DIALECT=mysql

# Vector store. pgvector is active today; the config is reserved for future
# Pinecone/Qdrant/Weaviate/FAISS adapters without route-level changes.
VECTOR_PROVIDER=pgvector
VECTOR_BASE_URL=
VECTOR_API_KEY=

# Default number of results returned by POST /query
TOP_K=5

# Retrieval-time in-memory embedding cache.
# Ingest embeddings are not cached.
EMBED_CACHE_ENABLED=true
EMBED_CACHE_TTL_SECONDS=1800

# In-memory /generate-sql cache.
# Only status="ok" SQL generation responses are cached.
SQL_CACHE_ENABLED=true
SQL_CACHE_TTL_SECONDS=300

# Minimum learned-pattern use_count required for retrieval injection and manual embedding
MIN_PATTERN_USE_COUNT=2

# Minimum user-instruction confidence required for retrieval injection and manual embedding
MIN_INSTRUCTION_CONFIDENCE=0.5

# Optional Layer 2 retrieval rewrite before embedding.
# Uses one fail-open Ollama call per external request to expand business terms
# such as counselor/counsellor into schema terms such as employee.
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_MODEL_PROVIDER=
QUERY_REWRITE_MODEL=deepseek-coder:6.7b
QUERY_REWRITE_MODEL_API_KEY=
QUERY_REWRITE_MODEL_BASE_URL=
QUERY_REWRITE_FALLBACK_PROVIDER=
QUERY_REWRITE_FALLBACK_MODEL=
QUERY_REWRITE_FALLBACK_API_KEY=
QUERY_REWRITE_FALLBACK_BASE_URL=
QUERY_REWRITE_TIMEOUT=8
QUERY_REWRITE_MAX_TOKENS=120
QUERY_REWRITE_HINTS="counselor,counsellor,counsellors -> employee"

# Governance / rulebook system
GOVERNANCE_ENABLED=true
GOVERNANCE_ENABLED_RULES=all
# To disable specific rules (comma-separated):
# GOVERNANCE_ENABLED_RULES=schema_fidelity,query_safety,scope_boundary,single_statement,answer_grounding,uncertainty_declaration,self_verification,column_selection_quality,no_assumptions,user_rules_priority
GOVERNANCE_INJECT_REACT=true
GOVERNANCE_INJECT_SQL=true
GOVERNANCE_INJECT_ANSWER=true
# GOVERNANCE_ENABLED=false disables all governance injection
# and the review gate. Use for debugging or performance testing.
# GOVERNANCE_ENABLED_RULES=all enables all 10 rules.
# Individual rules can be excluded by listing the others.
# Removing schema_fidelity or query_safety from the list
# is not recommended for production use.

# Startup dependency enforcement.
# warn   = log provider/runtime readiness failures but still start
# strict = fail startup when provider config, MySQL readiness, or schema assets are not ready
STARTUP_ENFORCEMENT_MODE=warn
